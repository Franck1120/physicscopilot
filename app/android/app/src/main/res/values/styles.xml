<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark launch theme: matches the app's #0A0A0A background so there's
         no white flash before Flutter renders its first frame. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
    </style>
    <!-- NormalTheme: keep the dark window while Flutter initializes. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">#0A0A0A</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
    </style>
</resources>
