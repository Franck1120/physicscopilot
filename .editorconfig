# EditorConfig — https://editorconfig.org
# Consistent formatting across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[*.dart]
indent_style = space
indent_size = 2

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.sh]
indent_style = space
indent_size = 2
shell_variant = bash

[Makefile]
indent_style = tab

[*.{sql,psql}]
indent_style = space
indent_size = 2

[{Dockerfile,Dockerfile.*}]
indent_style = space
indent_size = 2
