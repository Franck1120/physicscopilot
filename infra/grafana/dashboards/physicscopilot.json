{
  "title": "PhysicsCopilot",
  "uid": "physicscopilot",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ws_active_connections",
          "legendFormat": "connections"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "AI Inference Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ai_inference_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_inference_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ai_inference_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Gemini Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(gemini_errors_total[1m])) by (type)",
          "legendFormat": "{{ type }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 4,
      "title": "Sessions by Language",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 4, "w": 4, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "ws_active_sessions_by_language",
          "legendFormat": "{{ language }}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Frames Processed per Minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(ws_frames_processed_total[1m]) * 60",
          "legendFormat": "frames/min"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "Server Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "go_memstats_alloc_bytes / 1024 / 1024",
          "legendFormat": "alloc MB"
        },
        {
          "expr": "go_memstats_sys_bytes / 1024 / 1024",
          "legendFormat": "sys MB"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "id": 7,
      "title": "Session Funnel",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "increase(session_started_total[1h])",
          "legendFormat": "Started"
        },
        {
          "expr": "increase(session_completed_total[1h])",
          "legendFormat": "Completed"
        },
        {
          "expr": "increase(session_abandoned_total[1h])",
          "legendFormat": "Abandoned"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 8,
      "title": "Time to First Response (TTFR) p50 / p95",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(session_time_to_first_response_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(session_time_to_first_response_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Errors by Category",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(app_errors_total[1m])) by (category)",
          "legendFormat": "{{ category }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ]
}
