# ─────────────────────────────────────────────────────────────────────────────
# PhysicsCopilot Server — Environment Variables
#
# Copy this file to .env and fill in the values before running the server.
# The server reads these at startup; missing required variables cause an error.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the server listens on.
# Default: 8080
PORT=8080

# Runtime environment label — controls CORS behaviour and log format.
# "production" → strict CORS + JSON structured logs; anything else → permissive CORS + human-readable logs.
# Default: development
APP_ENV=development

# Comma-separated list of allowed CORS origins.
# In production this MUST be set to your app's origin (e.g. https://yourapp.com).
# If unset in production, cross-origin requests are blocked.
# In development defaults to "*" when this variable is absent.
ALLOWED_ORIGINS=

# Password protecting the /metrics endpoint (HTTP Basic Auth, username = "metrics").
# Required to enable Prometheus metrics scraping.
# If unset, /metrics returns 503 Service Unavailable.
METRICS_PASSWORD=


# ── Gemini AI ─────────────────────────────────────────────────────────────────

# Google Gemini API key.
# Required when calling the Gemini REST API directly.
# Obtain one at https://aistudio.google.com
# When absent the server falls back to CLIPROXY_URL (see below).
GEMINI_API_KEY=

# Override the Gemini REST endpoint (useful for testing against a stub).
# Default: https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
# Leave blank to use the default production endpoint.
GEMINI_BASE_URL=

# Gemini model name — used only when routing through CLIProxyAPI.
# Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash


# ── CLIProxyAPI (local fallback) ──────────────────────────────────────────────

# Base URL of the local CLIProxyAPI Docker container.
# Used as a Gemini fallback when GEMINI_API_KEY is not set.
# The server appends /v1/chat/completions to this URL.
# Default: http://localhost:8085
CLIPROXY_URL=http://localhost:8085


# ── Supabase ──────────────────────────────────────────────────────────────────

# Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key — safe to expose to clients.
SUPABASE_ANON_KEY=your-anon-key

# JWT secret used by Supabase Auth — required to verify tokens server-side.
# Find it in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
